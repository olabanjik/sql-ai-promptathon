## Supporting SQL: Task 6 Cluster Analysis
```sql
DECLARE @DocId int = 39;
WITH Similar AS (
    SELECT DocId, SourceType, SourceId, RelatedSKU, RelatedOrderId, RelatedCustomerId, RelatedTicketId
    FROM dbo.FindSimilarDocsByDocId(@DocId, 8)
)
SELECT
    s.DocId,
    s.SourceType,
    s.SourceId,
    s.RelatedSKU,
    s.RelatedOrderId,
    s.RelatedCustomerId,
    s.RelatedTicketId,
    p.Category,
    p.ProductName,
    so.OrderType,
    so.Channel,
    c.CustomerSegment,
    c.Country,
    c.Language,
    so.ClientName,
    so.CustomerName
FROM Similar s
LEFT JOIN dbo.Products p ON s.RelatedSKU = p.SKU
LEFT JOIN dbo.SalesOrders so ON s.RelatedOrderId = so.OrderId
LEFT JOIN dbo.Customers c ON s.RelatedCustomerId = c.CustomerId
ORDER BY s.DocId;
```

